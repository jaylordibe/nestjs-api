# Production .env template. On the prod server, copy this to
# /srv/${SERVICE_NAME}/.env and fill in the values marked REQUIRED. Pairs
# with `docs/prod/docker-compose.yml`. Staging has its own template
# (`docs/staging/.env.example`) and its own compose file
# (`docs/staging/docker-compose.yml`) — the two environments are kept
# fully separate so each can drift to fit its host platform without
# leaking config into the other.
#
# Different from the repo-root .env.example: that one targets `yarn
# start:dev` on the host (data services on localhost ports); this one
# targets the docker compose stack (services on the internal docker
# network, behind Cloudflare/Caddy).
#
# Values are read in two phases:
#   1. docker compose itself interpolates ${VAR} into docker-compose.yml at
#      `up` time (SERVICE_NAME, DB_*, REDIS_PASSWORD, *_HOSTNAME, VITE_*).
#   2. The api container loads this file via `env_file: .env`, then the
#      compose `environment:` block overrides DATABASE_URL/REDIS_URL with
#      container-network hostnames. So DB_HOST/REDIS_HOST below are mostly
#      cosmetic for the api container — but Joi still validates them, so
#      keep them set to the docker service names below.

NODE_ENV="production"
PORT=3000

SERVICE_NAME="nestjs"

# Commit hash of the running build. The deploy workflow exports GIT_SHA
# (`git rev-parse HEAD`) before `compose up --build`; compose forwards it
# as a build arg. Leave blank here — the workflow sets it at deploy time.
GIT_SHA=""

# ─── public hostnames ───────────────────────────────────────────────
# Consumed by the Caddyfile (routes inbound traffic by hostname) and by
# the Vite build args below (baked into the SPA bundles). Both must
# be set up in Cloudflare DNS as proxied A records → your server's IP.
# (apex + www both resolve to WEB_HOSTNAME; see the Caddyfile.)
API_HOSTNAME="api.example.com"
WEB_HOSTNAME="example.com"          # apex; Caddyfile 301-redirects it to www.

# The API's own base URL — used when building clickable email links the
# backend handles directly (e.g. GET /api/auth/verify-email?token=…). No
# trailing slash — Joi enforces it.
API_BASE_URL="https://${API_HOSTNAME}/api"

# Customer-facing web frontend base URL — distinct from API_BASE_URL.
# Used by emails that link customers to pages they actually browse
# (verification redirect target, booking CTAs, etc.). Points at the
# canonical www host — the apex 301-redirects there, so aiming email
# links straight at www avoids a needless redirect hop. No trailing slash.
WEB_BASE_URL="https://www.${WEB_HOSTNAME}"

# ─── postgres ───────────────────────────────────────────────────────
DB_USER="${SERVICE_NAME}"
# REQUIRED. Generate: openssl rand -base64 32
DB_PASSWORD=""
DB_HOST="postgres"   # docker service name
DB_PORT=5432
DB_NAME="${SERVICE_NAME}"
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public"

# ─── redis ──────────────────────────────────────────────────────────
REDIS_HOST="redis"
REDIS_PORT=6379
# REQUIRED. Min 16 chars (Joi). Generate: openssl rand -base64 32
REDIS_PASSWORD=""
REDIS_URL="redis://default:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}"

# ─── auth ───────────────────────────────────────────────────────────
# REQUIRED. Min 16 chars (Joi). Generate: openssl rand -hex 48
# Joi rejects an empty value at boot — regenerate a unique value per env so
# a template-shared secret can't forge tokens across deployments.
JWT_SECRET=""
JWT_EXPIRES_IN="30d"

# ─── email ──────────────────────────────────────────────────────────
# `stub` only logs to stdout — switch to `resend` in prod and set the
# two values below. EMAIL_FROM's domain must have DKIM/SPF/DMARC verified
# in the Resend dashboard or messages land in spam.
EMAIL_PROVIDER="resend"
EMAIL_FROM="App Name <noreply@example.com>"
# REQUIRED when EMAIL_PROVIDER=resend.
RESEND_API_KEY=""

# Public web URL the API redirects to after a GET /auth/verify-email
# click. Defaults to ${WEB_BASE_URL}/auth/verify-email — set explicitly
# only if the verify page lives at a different path or hostname.
# EMAIL_VERIFIED_REDIRECT_URL="https://www.example.com/auth/verify-email"

# ─── SMS ────────────────────────────────────────────────────────────
# `stub` only logs — phone-verification OTPs would never reach the user.
# Switch to `twilio` and set the three values below for the phone-update
# flow to actually deliver codes.
SMS_PROVIDER="twilio"
# REQUIRED when SMS_PROVIDER=twilio. From the Twilio console under
# Account → API keys & tokens.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
# Either an E.164 number provisioned in the Twilio console (e.g.
# "+15551234567") or a Messaging Service SID starting with "MG…". Sender
# numbers must be enabled for SMS in the destination country.
TWILIO_FROM=""

# ─── file storage (S3-compatible) ───────────────────────────────────
# `stub` returns fake stub:// URLs (no persistence). Switch to `s3` in
# prod and supply at minimum STORAGE_S3_BUCKET + STORAGE_S3_REGION. AWS
# credentials come from the standard SDK chain — set the two AWS_* vars
# below for static keys, or rely on instance/task IAM roles on AWS-hosted
# compute (leave them blank). Works with any S3-compatible backend
# (Cloudflare R2, DigitalOcean Spaces, MinIO) via STORAGE_S3_ENDPOINT.
STORAGE_PROVIDER="s3"
STORAGE_S3_BUCKET=""
STORAGE_S3_REGION="us-east-1"
# Optional CDN base — defaults to https://<bucket>.s3.<region>.amazonaws.com.
# STORAGE_S3_PUBLIC_URL_BASE="https://cdn.example.com"
# Set when using Cloudflare R2 / DigitalOcean Spaces / MinIO. Leave empty for AWS.
# STORAGE_S3_ENDPOINT=""
# STORAGE_S3_FORCE_PATH_STYLE="false"
# Static credentials (skip these and leave blank when using an instance/
# task IAM role). Treat as sensitive — never commit real values.
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""

# ─── CORS ───────────────────────────────────────────────────────────
# Joi rejects "*" in production. List every browser-facing origin that
# calls the API. The bare apex (${WEB_HOSTNAME}) is intentionally absent —
# Caddy 301-redirects it to www before any page loads, so no document ever
# runs with the apex origin and the API can never see it as a request origin.
CORS_ORIGIN="https://www.${WEB_HOSTNAME}"

# ─── rate limiting ──────────────────────────────────────────────────
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# ─── trust proxy ────────────────────────────────────────────────────
# Two hops in front of the app: Cloudflare → Caddy → app. Joi rejects
# "true"/"false" in production. Set to the integer hop count, or a CIDR
# list if you want to lock it down to known proxy IPs.
TRUST_PROXY=2

# ─── Vite build args (per-SPA) ──────────────────────────────────────
# Vite bakes env vars into the bundle at BUILD time. Browsers load the
# bundle, so use the publicly-reachable API URL — NOT `http://api:3000`,
# which only resolves inside the docker network.
#
# Each SPA owns its own build args (no cross-portal coupling). Add new
# keys here AND under the matching service's `build.args` in
# docs/prod/docker-compose.yml.

# Customer web SPA.
WEB_VITE_API_BASE_URL="https://${API_HOSTNAME}/api"

# ─── seed (first deploy only) ───────────────────────────────────────
# Used by `yarn prisma:seed` when bootstrapping a fresh database. Safe
# to leave blank after the first deploy — the seeder is idempotent and
# only refuses to run if invoked with empty values.
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
SEED_USER_EMAIL=""
SEED_USER_PASSWORD=""
