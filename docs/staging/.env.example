# Staging .env template. On the staging server, copy this to
# /srv/${SERVICE_NAME}/.env and fill in the values marked REQUIRED. Pairs
# with `docs/staging/docker-compose.yml`. Production has its own template
# (`docs/prod/.env.example`) and its own compose file
# (`docs/prod/docker-compose.yml`) — the two environments are kept fully
# separate so each can drift to fit its host platform without leaking
# config into the other.
#
# Different from the repo-root .env.example: that one targets `yarn
# start:dev` on the host (data services on localhost ports); this one
# targets the docker compose stack (services on the internal docker
# network, behind Cloudflare/Caddy).
#
# Values are read in two phases:
#   1. docker compose itself interpolates ${VAR} into docker-compose.yml at
#      `up` time (SERVICE_NAME, DB_*, REDIS_PASSWORD, *_HOSTNAME, VITE_*).
#   2. The api container loads this file via `env_file: .env`, then the
#      compose `environment:` block overrides DATABASE_URL/REDIS_URL with
#      container-network hostnames. So DB_HOST/REDIS_HOST below are mostly
#      cosmetic for the api container — but Joi still validates them, so
#      keep them set to the docker service names below.

# Distinguishes staging from production at runtime so /api/docs stays
# reachable here while it's hidden in prod, and so any future "differs
# from prod" decision has a single signal to branch on. The Joi
# production-style guards (CORS_ORIGIN cannot be `*`, TRUST_PROXY must be
# explicit) ALSO fire when this is "staging" — we still serve real DNS
# here. Don't "fix" this back to "production".
NODE_ENV="staging"
PORT=3000

SERVICE_NAME="nestjs"

# Commit hash of the running build. The deploy workflow exports GIT_SHA
# (`git rev-parse HEAD`) before `compose up --build`; compose forwards it
# as a build arg. Leave blank here — the workflow sets it at deploy time.
GIT_SHA=""

# ─── public hostnames ───────────────────────────────────────────────
# Consumed by the Caddyfile (routes inbound traffic by hostname) and by
# the Vite build args below (baked into the SPA bundles). Both must
# be set up in Cloudflare DNS as proxied A records → your server's IP.
# (apex + www both resolve to WEB_HOSTNAME; see the Caddyfile.)
API_HOSTNAME="api.staging.example.com"
WEB_HOSTNAME="staging.example.com"          # apex; Caddyfile 301-redirects it to www.

# The API's own base URL — used when building clickable email links the
# backend handles directly (e.g. GET /api/auth/verify-email?token=…). No
# trailing slash — Joi enforces it.
API_BASE_URL="https://${API_HOSTNAME}/api"

# Customer-facing web frontend base URL — distinct from API_BASE_URL.
# Used by emails that link customers to pages they actually browse
# (verification redirect target, booking CTAs, etc.). Points at the
# canonical www host — the apex 301-redirects there, so aiming email
# links straight at www avoids a needless redirect hop. No trailing slash.
WEB_BASE_URL="https://www.${WEB_HOSTNAME}"

# ─── postgres ───────────────────────────────────────────────────────
DB_USER="${SERVICE_NAME}"
# REQUIRED. Generate: openssl rand -base64 32
DB_PASSWORD=""
DB_HOST="postgres"   # docker service name
DB_PORT=5432
DB_NAME="${SERVICE_NAME}"
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public"

# ─── redis ──────────────────────────────────────────────────────────
REDIS_HOST="redis"
REDIS_PORT=6379
# REQUIRED. Min 16 chars (Joi). Generate: openssl rand -base64 32
REDIS_PASSWORD=""
REDIS_URL="redis://default:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}"

# ─── auth ───────────────────────────────────────────────────────────
# REQUIRED. Min 16 chars (Joi). Generate: openssl rand -hex 48
# Joi rejects an empty value at boot — regenerate a unique value per env so
# a template-shared secret can't forge tokens across deployments.
JWT_SECRET=""
JWT_EXPIRES_IN="30d"

# ─── email ──────────────────────────────────────────────────────────
# Staging typically uses `stub` so test signups don't send real emails —
# flip to `resend` only if you need to verify deliverability against real
# inboxes (then set EMAIL_FROM on a DKIM/SPF/DMARC-verified domain).
EMAIL_PROVIDER="stub"
EMAIL_FROM="App Name Staging <noreply@example.com>"
# REQUIRED when EMAIL_PROVIDER=resend.
RESEND_API_KEY=""

# Public web URL the API redirects to after a GET /auth/verify-email
# click. Defaults to ${WEB_BASE_URL}/auth/verify-email — set explicitly
# only if the verify page lives at a different path or hostname.
# EMAIL_VERIFIED_REDIRECT_URL="https://www.staging.example.com/auth/verify-email"

# ─── SMS ────────────────────────────────────────────────────────────
# Staging typically keeps `stub` so test phone-update flows don't burn
# Twilio quota. Switch to `twilio` and set the three values below for the
# phone-update flow to actually deliver codes.
SMS_PROVIDER="stub"
# REQUIRED when SMS_PROVIDER=twilio. From the Twilio console under
# Account → API keys & tokens.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
# Either an E.164 number provisioned in the Twilio console or a Messaging
# Service SID starting with "MG…".
TWILIO_FROM=""

# ─── file storage (S3-compatible) ───────────────────────────────────
# Use a staging-only bucket so test uploads never land in prod. `stub`
# returns fake stub:// URLs (no persistence); switch to `s3` and supply at
# minimum STORAGE_S3_BUCKET + STORAGE_S3_REGION. AWS credentials come from
# the standard SDK chain — set the AWS_* vars for static keys, or rely on
# instance/task IAM roles (leave them blank). Works with any S3-compatible
# backend (Cloudflare R2, DigitalOcean Spaces, MinIO) via STORAGE_S3_ENDPOINT.
STORAGE_PROVIDER="stub"
STORAGE_S3_BUCKET=""
STORAGE_S3_REGION="us-east-1"
# STORAGE_S3_PUBLIC_URL_BASE="https://cdn.staging.example.com"
# STORAGE_S3_ENDPOINT=""
# STORAGE_S3_FORCE_PATH_STYLE="false"
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""

# ─── CORS ───────────────────────────────────────────────────────────
# Joi rejects "*" in production-style envs (staging included). List every
# browser-facing origin that calls the staging API. The bare apex
# (${WEB_HOSTNAME}) is intentionally absent — Caddy 301-redirects it to
# www before any page loads, so the API never sees it as a request origin.
CORS_ORIGIN="https://www.${WEB_HOSTNAME}"

# ─── rate limiting ──────────────────────────────────────────────────
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# ─── trust proxy ────────────────────────────────────────────────────
# Two hops in front of the app: Cloudflare → Caddy → app. Joi rejects
# "true"/"false" in production-style envs. Set to the integer hop count,
# or a CIDR list if you want to lock it down to known proxy IPs.
TRUST_PROXY=2

# ─── Vite build args (per-SPA) ──────────────────────────────────────
# Vite bakes env vars into the bundle at BUILD time. Browsers load the
# bundle, so use the publicly-reachable API URL — NOT `http://api:3000`,
# which only resolves inside the docker network.
#
# Each SPA owns its own build args (no cross-portal coupling). Add new
# keys here AND under the matching service's `build.args` in
# docs/staging/docker-compose.yml.

# Customer web SPA.
WEB_VITE_API_BASE_URL="https://${API_HOSTNAME}/api"

# ─── seed (first deploy only) ───────────────────────────────────────
# Used by `yarn prisma:seed` when bootstrapping a fresh database. Safe
# to leave blank after the first deploy — the seeder is idempotent and
# only refuses to run if invoked with empty values.
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
SEED_USER_EMAIL=""
SEED_USER_PASSWORD=""

# ─── Swagger Basic Auth (staging only) ──────────────────────────────
# Production has Swagger disabled at the Nest layer (see main.ts).
# Staging keeps it enabled but locks /api/docs* behind HTTP Basic Auth
# at the Caddy edge — see `basic_auth @docs` in the Caddyfile. Anyone who
# guesses the staging hostname hits a browser login prompt before the schema.
#
# To set/rotate:
#   1. ssh to the staging host, cd /srv/<service>
#   2. docker compose exec caddy caddy hash-password
#      (paste the password you want; copy the bcrypt $2a$... output)
#   3. Paste the bcrypt hash into SWAGGER_BASIC_AUTH_PASSWORD_HASH below,
#      WRAPPED IN SINGLE QUOTES — see gotcha.
#   4. docker compose up -d caddy
#      (a `caddy reload` won't pick up new docker env vars; only
#      recreating the container re-reads the .env file.)
#
# Gotcha — single quotes, NOT double:
#   bcrypt hashes start with `$2a$14$...`. Docker Compose performs `${VAR}`
#   interpolation on values it loads from .env, which would try to expand
#   `$2a` / `$<salt>` as variable refs and warn "variable is not set".
#   Single-quoting the value disables interpolation; double quotes do NOT:
#     SWAGGER_BASIC_AUTH_PASSWORD_HASH='$2a$14$...'   ✓
#     SWAGGER_BASIC_AUTH_PASSWORD_HASH="$2a$14$..."   ✗  (warnings, empty)
#     SWAGGER_BASIC_AUTH_PASSWORD_HASH=$2a$14$...     ✗  (same)
#
# Share the raw username + password with the team via your secrets
# manager. Never commit the raw password — only the bcrypt hash lives on disk.
SWAGGER_BASIC_AUTH_USER=""
SWAGGER_BASIC_AUTH_PASSWORD_HASH=''
