# Copy to .env.staging on the staging server. NEVER commit the real file.
# Required by both docker compose interpolation AND the running app.

NODE_ENV="staging"
PORT=3000

# Host port that the in-compose nginx publishes for HTTP (and 443 for HTTPS
# once TLS is configured). Change if 80 is taken by something else on this host.
NGINX_HOST_PORT=80
NGINX_HOST_PORT_TLS=443

SERVICE_NAME="nestjs"

DB_USER="nestjs"
# IMPORTANT: regenerate per-environment. `openssl rand -base64 24 | tr -d /+=`
DB_PASSWORD="REPLACE_WITH_STAGING_DB_PASSWORD"
# DB_HOST and DATABASE_URL are overridden in docker-compose.staging.yml so
# the API talks to the postgres service over the docker network. Leave these
# values here for completeness / for any tooling that reads the env file.
DB_HOST="localhost"
DB_PORT=5432
DB_NAME="nestjs_staging"
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public"

REDIS_HOST="localhost"
REDIS_PORT=6379
# IMPORTANT: regenerate per-environment.
REDIS_PASSWORD="REPLACE_WITH_STAGING_REDIS_PASSWORD"
REDIS_URL="redis://default:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}"

# IMPORTANT: regenerate per-environment. `openssl rand -hex 48`
JWT_SECRET="REPLACE_WITH_STAGING_JWT_SECRET"
JWT_EXPIRES_IN="30d"

# Lock to the QA frontend's domain. Use comma-separated for multiple.
CORS_ORIGIN="https://qa.example.com"

# With nginx-in-Docker as the only proxy, '1' means "trust 1 hop" so
# Express reads the real client IP from X-Forwarded-For (used by throttler,
# audit logs, etc.). Bump to '2' if you add a CDN/ALB in front.
TRUST_PROXY="1"

# Tighter than the global default in production-like environments.
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=60
