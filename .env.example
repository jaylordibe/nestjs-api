NODE_ENV="development"
PORT=3000

SERVICE_NAME="nestjs"

# Base URL used when building clickable email links (e.g. verification
# links). Point at your frontend if you have one, otherwise at the API
# base — the backend has a GET /auth/verify-email?token=… endpoint that
# handles the click directly. No trailing slash.
API_BASE_URL="http://localhost:3000/api"

# Customer-facing web frontend base URL — distinct from API_BASE_URL
# (which is the API). Used by emails that link customers to pages they
# actually browse (booking confirmation CTAs, marketing pages, etc.).
# Default targets the Vite dev port; production must be set to the real
# web hostname (e.g. https://yourapp.com). No trailing slash.
WEB_BASE_URL="http://localhost:5173"

DB_USER="${SERVICE_NAME}"
DB_PASSWORD="0UFOZeHfdwbzc2aFzj6dv"
DB_HOST="localhost"
DB_PORT=5433
DB_NAME="${SERVICE_NAME}_local"

DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public"

REDIS_HOST="localhost"
REDIS_PORT=6378
REDIS_PASSWORD="bVVrWPX1HGfiNwZmwZFOkON"
REDIS_URL="redis://default:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}"

# REQUIRED: generate a unique value per deployment, e.g. `openssl rand -hex 48`.
# Left blank here so Joi's .min(16).required() check blocks boot on a fresh
# clone — a template-shared secret would let anyone forge tokens for any
# deployment that forgot to regenerate.
JWT_SECRET=""
# 30 days matches consumer-app expectations (Facebook, Instagram, most
# booking/social apps) — users shouldn't have to re-login daily. The real
# kill switch is passwordChangedAt: when a user rotates their password,
# JwtStrategy rejects every token issued before that second, so a stolen
# token dies the moment the real user reacts. For higher-value apps
# (banking, healthcare, admin consoles), drop this to 1h + add a refresh
# token flow.
JWT_EXPIRES_IN="30d"

# Backstop TTL (seconds) for the per-user permission-grants cache in Redis.
# Role and membership changes invalidate the cache explicitly, so this only
# bounds the window of a missed invalidation. Default 300.
AUTHORIZATION_GRANTS_CACHE_TTL_SECONDS=300

# Email provider. `stub` logs messages to stdout — good for local dev and
# tests (OTPs still visible in the console so manual flows work). Set to
# `resend` in staging/prod, supply RESEND_API_KEY + EMAIL_FROM, and make
# sure EMAIL_FROM is on a domain you've verified in the Resend dashboard
# (DKIM + SPF + DMARC set in DNS) — otherwise sends land in spam.
EMAIL_PROVIDER="stub"
# EMAIL_FROM="App Name <noreply@yourapp.com>"
# RESEND_API_KEY=""

# SMS provider. `stub` logs messages to stdout — OTPs surface in the app
# console for local flows. Set to `twilio` in staging/prod and supply the
# three TWILIO_* values. TWILIO_FROM may be either an E.164 phone number
# you've provisioned in the Twilio console (e.g. "+15551234567") or a
# Messaging Service SID starting with "MG…".
SMS_PROVIDER="stub"
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM=""

# File storage provider. `stub` logs uploads + returns fake `stub://...`
# URLs (no real persistence) — good for local dev and tests. Set to `s3`
# in staging/prod and supply at minimum STORAGE_S3_BUCKET +
# STORAGE_S3_REGION. AWS credentials come from the standard SDK chain
# (env vars `AWS_ACCESS_KEY_ID` / `AWS_SECRET_ACCESS_KEY`, shared config,
# or instance/task IAM roles on AWS-hosted compute). Works with any
# S3-compatible backend — set STORAGE_S3_ENDPOINT for Cloudflare R2,
# DigitalOcean Spaces, or self-hosted MinIO.
STORAGE_PROVIDER="stub"
# STORAGE_S3_BUCKET=""
# STORAGE_S3_REGION="us-east-1"
# Optional CDN base — defaults to https://<bucket>.s3.<region>.amazonaws.com.
# STORAGE_S3_PUBLIC_URL_BASE="https://cdn.yourapp.com"
# Set when using Cloudflare R2 / DigitalOcean Spaces / MinIO. Leave empty for AWS.
# STORAGE_S3_ENDPOINT=""
# STORAGE_S3_FORCE_PATH_STYLE="false"

# Public web URL the API redirects to after a GET /auth/verify-email
# click. The web app reads `?status=success|error&reason=…` from the
# query string and renders the matching state. Defaults to
# `${WEB_BASE_URL}/auth/verify-email` — set explicitly when the verify
# page lives at a different path or hostname.
# EMAIL_VERIFIED_REDIRECT_URL="https://yourapp.com/auth/verify-email"

CORS_ORIGIN="*"

# Global rate limit applied via @nestjs/throttler. THROTTLE_LIMIT requests
# per THROTTLE_TTL_MS window per IP. Auth/sign-up endpoints override this
# with a stricter per-route limit.
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# Express `trust proxy` setting. Required when the API runs behind a reverse
# proxy (nginx, ALB, Cloudflare, k8s ingress) so that req.ip and the throttler
# see the real client IP from X-Forwarded-For instead of the proxy's IP.
#   "false" = direct exposure, no proxy (default — safe for local dev)
#   "1"     = trust 1 proxy hop (typical: single nginx/ALB in front)
#   "loopback,linklocal,uniquelocal" = trust private-range proxies
#   "true"  = trust everything (UNSAFE — lets any client spoof X-Forwarded-For
#             and bypass per-IP rate limits)
TRUST_PROXY=false

# Default users created by `yarn prisma:seed`. Override these in your
# staging/prod env before running the seeder — the script refuses to run
# if either email or password is missing, and enforces the same password
# complexity the app itself enforces (12+ chars, letter + digit).
# Re-running the seeder is idempotent: existing users are left untouched.
#
# The seeder also projects the permission catalog onto the database: every
# permission, the eight system roles, and their grants. The admin gets
# PLATFORM_ADMIN + PLATFORM_USER; the regular user gets PLATFORM_USER.
# The app refuses to boot if the database and the catalog disagree.
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="admin-local-dev-1"
SEED_USER_EMAIL="user@example.com"
SEED_USER_PASSWORD="user-local-dev-1"
