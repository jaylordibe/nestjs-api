# Copy to .env.production on the production server. NEVER commit the real file.
# Required by both docker compose interpolation AND the running app.

NODE_ENV="production"
PORT=3000

# Host port that the in-compose nginx publishes. Almost always 80 / 443.
NGINX_HOST_PORT=80
NGINX_HOST_PORT_TLS=443

SERVICE_NAME="nestjs"

DB_USER="nestjs"
# IMPORTANT: regenerate per-environment. `openssl rand -base64 24 | tr -d /+=`
# This is the production DB credential — treat it like a secret. Never reuse staging.
DB_PASSWORD="REPLACE_WITH_PRODUCTION_DB_PASSWORD"
# DB_HOST and DATABASE_URL are overridden in docker-compose.production.yml so
# the API talks to the postgres service over the docker network. Leave these
# values here for completeness / for any tooling that reads the env file.
DB_HOST="localhost"
DB_PORT=5432
DB_NAME="nestjs_production"
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public"

REDIS_HOST="localhost"
REDIS_PORT=6379
# IMPORTANT: regenerate per-environment.
REDIS_PASSWORD="REPLACE_WITH_PRODUCTION_REDIS_PASSWORD"
REDIS_URL="redis://default:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}"

# IMPORTANT: regenerate per-environment. `openssl rand -hex 48`
# A leak of this lets anyone forge tokens for any user. Treat with the same
# care as your DB password.
JWT_SECRET="REPLACE_WITH_PRODUCTION_JWT_SECRET"
# Consider a shorter expiry in production if you don't have refresh tokens
# and need quicker session revocation. 30d is a typical mobile-app value.
JWT_EXPIRES_IN="30d"

# Lock to your real frontend's origin(s). Comma-separated for multiple.
# Avoid '*' in production — it disables CORS protection.
CORS_ORIGIN="https://app.example.com"

# With nginx-in-Docker as the only proxy, '1' means "trust 1 hop" so
# Express reads the real client IP from X-Forwarded-For (throttler, audit
# logs, etc.). Bump to '2' if you add Cloudflare / CDN / ALB in front of nginx.
TRUST_PROXY="1"

# Production rate limit. Tune based on real traffic — 60 req/min/IP is a
# defensive default; raise if legitimate clients (mobile app polling, etc.)
# need more. Per-route stricter limits on /auth/login and /auth/register
# (10/min and 5/min) are hardcoded in the controller and apply on top.
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=60
