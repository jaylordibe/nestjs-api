<!doctype html>
<html>
  <body style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; line-height: 1.5; color: #111; max-width: 480px; margin: 0 auto; padding: 24px;">
    <h1 style="font-size: 20px; margin: 0 0 16px;">You already have an account</h1>
    <p>Hi {{firstName}},</p>
    <p>Someone just tried to sign up using this email address at <strong>{{occurredAt}}</strong>. You don't need to — this email already has an account. Sign in instead:</p>
    <p style="margin: 32px 0;">
      <a href="{{{signInUrl}}}" style="display: inline-block; background: #111; color: #fff; text-decoration: none; padding: 12px 24px; border-radius: 6px; font-weight: 600;">Sign in</a>
    </p>
    <p style="color: #666; font-size: 14px;">Or paste this link into your browser:</p>
    <p style="color: #666; font-size: 13px; word-break: break-all;"><a href="{{{signInUrl}}}" style="color: #666;">{{{signInUrl}}}</a></p>
    <p style="color: #666; font-size: 14px; margin-top: 24px;">Forgot your password? Use <strong>Forgot password</strong> on the sign-in page to reset it.</p>
    <p style="color: #666; font-size: 14px;">If this wasn't you, no action is needed — nothing about your account has changed and no new account was created. Your password still works as before.</p>
  </body>
</html>
