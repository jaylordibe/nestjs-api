NODE_ENV="test"
PORT=3001

SERVICE_NAME="nestjs"

# The e2e stack runs as its OWN set of containers, alongside (never instead
# of) the dev stack — `<service>-test-postgres` / `-redis` on their own
# ports, project, network and volumes. Same docker-compose.yml, different
# env file:
#
#   dev   → docker compose up -d                        (5433 / 6378)
#   test  → docker compose --env-file .env.test up -d   (5434 / 6380)
#
# COMPOSE_PROJECT_NAME namespaces the project (and therefore the volumes, so
# the two can never share data); COMPOSE_STACK_SUFFIX feeds the compose
# `container_name`, which is global and would otherwise collide. Both are
# read by compose straight from this file.
#
# Why separate containers at all: test/setup/global-setup.ts issues a real
# `DROP DATABASE` on every e2e run. Pointed at the dev server that is one
# bad substitution away from dev data; on its own server it cannot reach it.
COMPOSE_PROJECT_NAME="${SERVICE_NAME}-test"
COMPOSE_STACK_SUFFIX="-test"

DB_USER="${SERVICE_NAME}"
DB_PASSWORD="0UFOZeHfdwbzc2aFzj6dv"
DB_HOST="localhost"
DB_PORT=5434
DB_NAME="${SERVICE_NAME}_test"

DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public"

REDIS_HOST="localhost"
REDIS_PORT=6380
REDIS_PASSWORD="bVVrWPX1HGfiNwZmwZFOkON"
# Logical DB 1. `truncateAll` flushes the keyspace between specs and REFUSES
# to flush DB 0, so a URL that ever gets repointed at the dev container fails
# loudly instead of wiping a developer's keys. Parallel workers each take
# their own index (worker N → /N, see test/setup/worker-isolation.ts), so
# this value is the single-worker default rather than a fixed assignment.
REDIS_URL="redis://default:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/1"

JWT_SECRET="test-only-jwt-secret-not-for-production-use-anywhere-ever"
JWT_EXPIRES_IN="1h"

CORS_ORIGIN="*"

THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
API_BASE_URL="http://localhost:3001/api"
